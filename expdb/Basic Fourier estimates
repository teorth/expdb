import Mathlib

open MeasureTheory Real Complex Filter Topology BigOperators

noncomputable section

/-- The blueprint's normalization `e(θ) = exp(2π i θ)`. -/
def e (θ : ℝ) : ℂ := Complex.exp (2 * Real.pi * Complex.I * θ)

@[simp] lemma e_def (θ : ℝ) : e θ = Complex.exp (2 * Real.pi * Complex.I * θ) := rfl

lemma abs_e (θ : ℝ) : ‖e θ‖ = 1 := by
  -- e θ = exp(2π i θ) = exp((2πθ) i) = exp(i • (2πθ)), a purely imaginary
  -- exponent, hence has norm exp(0) = 1.
  have h : (2 * Real.pi * Complex.I * θ : ℂ)
      = ((2 * Real.pi * θ : ℝ) : ℂ) * Complex.I := by
    push_cast; ring
  rw [e_def, h, Complex.norm_exp_ofReal_mul_I]

/-- A finite family `ξ : Fin R → ℝ` is `(1/N)`-separated if all pairwise
    distinct frequencies differ by at least `1/N`. -/
def SeparatedFreqs (N : ℝ) {R : ℕ} (ξ : Fin R → ℝ) : Prop :=
  ∀ r s : Fin R, r ≠ s → |ξ r - ξ s| ≥ 1 / N

/-- The exponential sum `F(t) = ∑_{r=1}^R a_r e(ξ_r t)`. -/
def expSum {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ) (t : ℝ) : ℂ :=
  ∑ r, a r * e (ξ r * t)

/-- The Fourier transform `ψ̂(u) := ∫_ℝ ψ(x) e(-x u) dx`, using the
    blueprint's normalization `e(θ) = exp(2π i θ)`.  We define this
    directly (rather than relying on Mathlib's `𝓕` notation, whose sign
    convention for the bicharacter may differ) so that the statements of
    Goals 2–6 match the blueprint exactly. -/
def psiHat (ψ : ℝ → ℝ) (u : ℝ) : ℂ := ∫ x : ℝ, (ψ x : ℂ) * e (-(x * u))

/-! ## Goal 1 : WLOG normalization

  We do **not** literally rescale `a` (that would change the statement of
  the lemma we are proving for a downstream user).  Instead Goal 1 is
  recorded as the trivial algebraic fact used inside the proof of Goal 2 :
  if `M := ∑ |a_r|^2 ≠ 0` and `A_r := a_r / √M`, then `∑ |A_r|^2 = 1`, and
  `expSum A ξ = expSum a ξ / √M` (so any identity proved for `A` rescales
  back to one for `a`).  When `M = 0` all `a_r = 0` and the lemma is
  trivial (`expSum a ξ ≡ 0`).
-/

lemma goal1_normalization {R : ℕ} (a : Fin R → ℂ)
    (M : ℝ) (hM : M = ∑ r, ‖a r‖ ^ 2) (hMpos : M ≠ 0) :
    ∑ r, ‖a r / (Real.sqrt M : ℂ)‖ ^ 2 = 1 := by
  have hMpos' : 0 < M := by
    rcases (hM ▸ Finset.sum_nonneg
      (fun r _ => sq_nonneg ‖a r‖)).lt_or_eq with h | h
    · exact h
    · exact absurd h.symm hMpos
  have hsqrt : (Real.sqrt M : ℝ) ≠ 0 := Real.sqrt_ne_zero'.mpr hMpos'
  have hnormsqrt : ‖(Real.sqrt M : ℂ)‖ = Real.sqrt M := by
    rw [Complex.norm_ofReal, abs_of_nonneg (Real.sqrt_nonneg M)]
  calc ∑ r, ‖a r / (Real.sqrt M : ℂ)‖ ^ 2
      = ∑ r, ‖a r‖ ^ 2 / M := by
        apply Finset.sum_congr rfl
        intro r _
        rw [norm_div, div_pow, hnormsqrt, Real.sq_sqrt hMpos'.le]
    _ = (∑ r, ‖a r‖ ^ 2) / M := by rw [Finset.sum_div]
    _ = 1 := by rw [← hM]; exact div_self hMpos

/-- If all `a r = 0` the exponential sum vanishes identically, and the
    Lemma 3.1 identity holds trivially (both sides are `0`). -/
lemma goal1_trivial_case {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (h : ∀ r, a r = 0) (I : Set ℝ) :
    ∫ t in I, ‖expSum a ξ t‖ ^ 2 = 0 := by
  have : ∀ t, expSum a ξ t = 0 := by
    intro t
    unfold expSum
    apply Finset.sum_eq_zero
    intro r _
    rw [h r, zero_mul]
  simp [this]

/-! ## A normalized smooth bump

  We fix once and for all a smooth, even, nonnegative `ψ : ℝ → ℝ`,
  supported on `[-1/4, 1/4]`, with `‖ψ‖_{L²} = 1`.  Existence of such a
  bump is standard (`exists_smooth_bump_compact_support` or a direct
  construction via `Real.smoothTransition`); we record only the
  properties we need as hypotheses of the lemmas below so that the
  precise construction is interchangeable.
-/

/-- The properties of `ψ` used throughout Goals 2–6. -/
structure BumpData where
  ψ : ℝ → ℝ
  smooth : ContDiff ℝ ⊤ ψ
  support : ∀ x, ψ x ≠ 0 → |x| ≤ 1 / 4
  nonneg : ∀ x, 0 ≤ ψ x
  l2norm_one : ∫ x, (ψ x) ^ 2 = 1

/-- Existence of `BumpData`.  Standard: take a smooth bump function on
    `(-1/4,1/4)`, normalize in `L²`.  We record it as an axiom-free
    existence statement to be discharged via Mathlib's
    `exists_smooth_bump_compact_support` (or `Real.smoothTransition`)
    plus rescaling by its `L²` norm. -/
