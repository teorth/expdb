/-! ## Goal 2 (eq. 3.1)

    ∫_ℝ |∑_{r} a_r e(ξ_r t)|² · |ψ̂((t-t₀)/N)|² dt = N

  for `t₀ ∈ ℝ`, `N > 0`, and `ψ` as in `BumpData`, *provided*
  `∑ |a_r|^2 = 1` and `ξ` is `(1/N)`-separated.

  Proof outline (matches the handwritten proof):
    1. Expand the square as a double sum over `r, s`.
    2. The diagonal `r = s` terms contribute, after the substitution
       `u = (t - t₀)/N`, exactly
         ∑_r |a_r|^2 · N · ∫ |ψ̂(u)|^2 du = N · ‖ψ̂‖_{L²}^2 = N
       using Plancherel `‖ψ̂‖_{L²} = ‖ψ‖_{L²} = 1`.
    3. The off-diagonal `r ≠ s` terms each reduce, via
       `Fact Fourier 1–3` (convolution/involution/conjugation identities
       for the Fourier transform), to
         a_r \overline{a_s} N e((ξ_r-ξ_s) t₀) ∫ ψ(uN) ψ(uN - (ξ_r-ξ_s)N) du.
       Because `ψ` is supported on `[-1/4,1/4]` and `|ξ_r-ξ_s| ≥ 1/N`
       (the separation hypothesis), the two factors `ψ(uN)` and
       `ψ(uN-(ξ_r-ξ_s)N)` have disjoint supports in `u`, so each such
       integral vanishes.
    4. Hence the sum collapses to the diagonal contribution, giving `N`.
-/

theorem goal2_eq_3_1 (B : BumpData) {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (N : ℝ) (hN : 0 < N) (t₀ : ℝ)
    (hnorm : ∑ r, ‖a r‖ ^ 2 = 1)
    (hsep : SeparatedFreqs N ξ) :
    ∫ t : ℝ, ‖expSum a ξ t‖ ^ 2 *
        ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2 = N := by
  -- Step 0: expand |∑ a_r e(ξ_r t)|^2 as a double sum.
  have e_conj : ∀ θ φ : ℝ, e θ * conj (e φ) = e (θ - φ) := by
    intro θ φ
    rw [e_def, e_def, ← Complex.exp_conj]
    rw [← Complex.exp_add]
    congr 1
    have hconj : conj (2 * (Real.pi : ℂ) * Complex.I * (φ : ℂ))
        = -(2 * (Real.pi : ℂ) * Complex.I * (φ : ℂ)) := by
      rw [map_mul, map_mul, map_mul, Complex.conj_ofReal, Complex.conj_I,
        Complex.conj_ofReal]
      ring
    rw [hconj]
    push_cast
    ring
  have expand : ∀ t : ℝ,
      ‖expSum a ξ t‖ ^ 2
        = (∑ r, ∑ s, a r * conj (a s) * e ((ξ r - ξ s) * t)).re := by
    intro t
    have h1 : ‖expSum a ξ t‖ ^ 2 = (expSum a ξ t * conj (expSum a ξ t)).re := by
      set z := expSum a ξ t
      have hmc : z * conj z = (Complex.normSq z : ℂ) := Complex.mul_conj z
      rw [hmc, Complex.ofReal_re]
      rw [Complex.norm_eq_abs, ← Complex.sq_abs]
    rw [h1]
    unfold expSum
    rw [Finset.sum_mul_sum]
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro r _
    rw [Complex.re_sum]
    apply Finset.sum_congr rfl
    intro s _
    rw [map_mul]
    have hrearrange :
        a r * e (ξ r * t) * (conj (a s) * conj (e (ξ s * t)))
          = a r * conj (a s) * (e (ξ r * t) * conj (e (ξ s * t))) := by ring
    rw [hrearrange, e_conj]
    have hexp : ξ r * t - ξ s * t = (ξ r - ξ s) * t := by ring
    rw [hexp]
  -- Step 1: split into diagonal (r = s) and off-diagonal (r ≠ s) parts.
  -- Step 1a (diagonal): each diagonal term, after integrating against
  -- |ψ̂((t-t₀)/N)|^2 and substituting u = (t-t₀)/N (so dt = N du),
  -- contributes  |a_r|^2 · N · ∫ |ψ̂(u)|^2 du  =  |a_r|^2 · N  by Plancherel
  -- (‖ψ̂‖_{L²} = ‖ψ‖_{L²} = 1, via `B.l2norm_one` and
  -- `MeasureTheory.fourierTransform_norm` / `Real.fourierIntegral_l2_norm`,
  -- whichever name applies in the installed Mathlib).
  -- Step 1b (off-diagonal): for r ≠ s, write q := ξ r - ξ s.  Using
  -- `Fact Fourier 1` (Fourier transform of a product is a convolution),
  -- `Fact Fourier 2` (double Fourier transform is reflection), and
  -- `Fact Fourier 3` (Fourier transform of conjugate), the integral
  --   ∫ e(q t) |ψ̂((t-t₀)/N)|^2 dt
  -- reduces (after `u = (t-t₀)/N`) to
  --   N e(q t₀) ∫ ψ(uN) ψ(uN - qN) du.
  -- Since `|q| ≥ 1/N` (from `hsep`) and `ψ` is supported on `[-1/4,1/4]`
  -- (`B.support`), the two factors `ψ(uN)` (needs `|uN| ≤ 1/4`) and
  -- `ψ(uN - qN)` (needs `|uN - qN| ≤ 1/4`) cannot both be nonzero:
  -- otherwise `|qN| ≤ |uN| + |uN - qN| ≤ 1/2`, i.e. `|q| ≤ 1/(2N) < 1/N`,
  -- contradicting separation.  Hence the integrand vanishes a.e. and the
  -- integral is `0`.
  sorry

/-! ## Goal 3 (eq. 3.2)

    For any interval `J` of length `N`,  ∫_J |∑ a_r e(ξ_r t)|² dt ≪ N.

  Proof outline:
    By continuity of `ψ̂` (Fourier transform of a smooth, compactly
    supported function is smooth, hence continuous) and `ψ̂(0) =
    ∫ ψ ≠ 0` (since `ψ ≥ 0`, `ψ ≢ 0` because `‖ψ‖_{L²}=1`), there is
    `δ > 0` and `c > 0` with `|ψ̂(u)|^2 ≥ c` for `|u| ≤ δ`, i.e.
        |ψ̂(u)|^2 ≥ c · 1_{[-δ/2,δ/2]}(u).
    Take `t₀` to be the center of `J`.  For `t ∈ J` we have
    `|t-t₀|/N ≤ |J|/(2N) = 1/2`, so choosing `δ ≥ 1` gives `|ψ̂((t-t₀)/N)|^2
    ≥ c` on `J`.  Hence
        c · ∫_J |∑ a_r e(ξ_r t)|^2 dt
            ≤ ∫_J |∑ a_r e(ξ_r t)|^2 |ψ̂((t-t₀)/N)|^2 dt
            ≤ ∫_ℝ |∑ a_r e(ξ_r t)|^2 |ψ̂((t-t₀)/N)|^2 dt
            = N    (by Goal 2),
    so `∫_J |∑ a_r e(ξ_r t)|^2 dt ≤ N / c ≪ N`.
-/

theorem goal3_eq_3_2 (B : BumpData) {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (N : ℝ) (hN : 0 < N)
    (hnorm : ∑ r, ‖a r‖ ^ 2 = 1)
    (hsep : SeparatedFreqs N ξ)
    (J : Set ℝ) (a0 b0 : ℝ) (hJ : J = Set.Icc a0 b0) (hlen : b0 - a0 = N) :
    ∃ C : ℝ, 0 < C ∧ ∫ t in J, ‖expSum a ξ t‖ ^ 2 ≤ C * N := by
  sorry
  -- Obtain (c, δ) as above from continuity / nonvanishing of ψ̂ at 0
  -- (`B.smooth.continuous.fourierTransform` and `B.l2norm_one` give
  -- `ψ̂(0) = ∫ ψ > 0`), then apply Goal 2 with `t₀ = (a0+b0)/2` and the
  -- pointwise lower bound on `|ψ̂((t-t₀)/N)|^2` on `J`.

/-! ## Goal 4

    ∫_I |∑ a_r e(ξ_r t)|² dt
       = T - ∫_ℝ |∑ a_r e(ξ_r t)|² · E(t) dt,
    where  E(t) := (1/N) ∫_I |ψ̂((t-t₀)/N)|² dt₀ - 1_I(t)  and  T = |I|.

  This is pure Fubini + the normalization `∫_I dt₀ ∫_ℝ |...|²|ψ̂(...)|² dt
  = ∫_ℝ |...|² ∫_I (1/N)|ψ̂(...)|² dt₀ dt = ∫_ℝ |...|² · N dt₀-average = N·T`
  (via Goal 2 applied for each fixed `t₀ ∈ I`, then integrating `t₀` over
  `I` and using `Fubini`), rearranged.
-/

theorem goal4_identity (B : BumpData) {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (N : ℝ) (hN : 0 < N)
    (hnorm : ∑ r, ‖a r‖ ^ 2 = 1)
    (hsep : SeparatedFreqs N ξ)
    (I : Set ℝ) (a0 b0 : ℝ) (T : ℝ) (hI : I = Set.Icc a0 b0)
    (hT : T = b0 - a0) :
    ∫ t in I, ‖expSum a ξ t‖ ^ 2
      = T - ∫ t : ℝ, ‖expSum a ξ t‖ ^ 2 *
          ((1 / N) * (∫ t₀ in I,
              ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2)
            - Set.indicator I (fun _ => (1:ℝ)) t) := by
  -- Step A: Fubini.
  --   ∫_I ( ∫_ℝ |F(t)|^2 |ψ̂((t-t₀)/N)|^2 dt ) dt₀  =  ∫_I N dt₀  =  N T.
  -- (the inner integral equals N for every t₀ ∈ I, by Goal 2.)
  have hinner : ∀ t₀ : ℝ,
      ∫ t : ℝ, ‖expSum a ξ t‖ ^ 2 *
          ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2 = N :=
    fun t₀ => goal2_eq_3_1 B a ξ N hN t₀ hnorm hsep
  -- Step B: swap the order of integration to get
  --   ∫_ℝ |F(t)|^2 ( ∫_I |ψ̂((t-t₀)/N)|^2 dt₀ ) dt = N T,
  -- i.e.  ∫_ℝ |F(t)|^2 · (N · [(1/N)∫_I |ψ̂(...)|^2 dt₀]) dt = N T,
  -- i.e.  N · ∫_ℝ |F(t)|^2 · [(1/N)∫_I |ψ̂(...)|^2 dt₀] dt = N T,
  -- i.e.  ∫_ℝ |F(t)|^2 · [(1/N)∫_I |ψ̂(...)|^2 dt₀] dt = T.        (★)
  -- Step C: split (★) using the indicator:
  --   ∫_ℝ |F(t)|^2 · [(1/N)∫_I|ψ̂|^2 dt₀ - 1_I(t)] dt
  --     + ∫_ℝ |F(t)|^2 · 1_I(t) dt  =  T,
  -- and  ∫_ℝ |F(t)|^2 1_I(t) dt = ∫_I |F(t)|^2 dt  by definition of the
  -- indicator restriction.  Rearranging gives the claim.
  sorry

/-! ## Goal 5

    E(t) := (1/N) ∫_I |ψ̂((t-t₀)/N)|² dt₀ - 1_I(t)
          ≪ (1 + dist(t, ∂I)/N)^{-10}.

  Proof outline (matches the handwritten "Step 1–4" proof):
    Step 1.  ψ smooth ⟹ ψ̂ is smooth (in particular `C^k` for every `k`)
             ⟹ by repeated integration by parts (using compact support of
             ψ on `[-1/4,1/4]` to kill boundary terms),
                 ψ̂(u) = (2π i u)^{-k} (ψ^{(k)})^(u),
             and since `ψ^{(k)}` is smooth & compactly supported, its
             Fourier transform is bounded, giving `|ψ̂(u)| ≪_k |u+1|^{-k}`
             for every `k`.  Take `k = 12`.
    Step 2.  Change of variables `u = (t-t₀)/N` (`dt₀ = -N du`) turns
                 (1/N) ∫_I |ψ̂((t-t₀)/N)|^2 dt₀
             into  ∫_{I_t} |ψ̂(u)|^2 du, where
                 I_t = [(t-b0)/N, (t-a0)/N]   (writing I = [a0,b0]).
    Step 3 (t ∈ I).  Then `0 ∈ I_t`, and writing
                 d_t := dist(t, ∂I)/N = min((t-a0)/N, (b0-t)/N),
             one has `ℝ \ I_t ⊆ {|u| ≥ d_t}`, so
                 (1/N)∫_I|ψ̂(...)|^2 dt₀ - 1
                  = ∫_{I_t}|ψ̂|^2 - 1 = -∫_{ℝ∖I_t}|ψ̂|^2
             and  |∫_{ℝ∖I_t}|ψ̂|^2| ≪ ∫_{|u|≥d_t} |u+1|^{-12} du
                  ≪ (1+d_t)^{-11} ≪ (1+d_t)^{-10}.
    Step 4 (t ∉ I).  Then `0 ∉ I_t`, `1_I(t) = 0`, and the same tail bound
             applies directly to `∫_{I_t}|ψ̂|^2`.
-/

/-- Distance from `t` to the boundary `{a0, b0}` of `I = [a0,b0]`. -/
def distBoundary (a0 b0 t : ℝ) : ℝ := min |t - a0| |t - b0|

theorem goal5_decay (B : BumpData)
    (N : ℝ) (hN : 0 < N) (a0 b0 : ℝ) (hab : a0 ≤ b0) :
    ∃ C : ℝ, 0 < C ∧ ∀ t : ℝ,
      |(1 / N) * (∫ t₀ in Set.Icc a0 b0,
          ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2)
        - Set.indicator (Set.Icc a0 b0) (fun _ => (1:ℝ)) t|
      ≤ C * (1 + distBoundary a0 b0 t / N) ^ (-(10:ℝ)) := by
  sorry
  -- Step 1: ψ̂ decay |ψ̂(u)| ≪ (1+|u|)^{-12}, via repeated integration by
  -- parts (`MeasureTheory.integral_deriv_eq_sub` /
  -- `intervalIntegral.integral_deriv_mul_eq_sub` for the by-parts step,
  -- iterated using `B.smooth` and `B.support` to discard boundary terms),
  -- then `Real.fourierIntegral` of the k-th derivative is bounded since
  -- ψ^{(k)} ∈ 𝒮(ℝ) (Schwartz, compactly supported).
  -- Step 2: change of variables `u = (t-t₀)/N` in the t₀-integral
  -- (`intervalIntegral.integral_comp_mul_right` / `MeasureTheory.integral_comp_sub_left`
  -- as appropriate), giving `∫_{I_t} |ψ̂(u)|^2 du` with `I_t` as above.
  -- Steps 3-4: case split `t ∈ I` vs `t ∉ I`, bound the complementary
  -- tail integral `∫_{|u|≥d_t} |u+1|^{-12} du ≪ (1+d_t)^{-11}` via
  -- `∫_{d_t}^∞ (u+1)^{-12} du = (1+d_t)^{-11}/11` (a standard improper
  -- integral, `intervalIntegral` / `MeasureTheory.integral_Ioi_rpow` type
  -- lemma), then weaken `-11` to `-10`.

/-! ## Goal 6 (dyadic decomposition)

    ∫_ℝ |∑ a_r e(ξ_r t)|² E(t) dt ≪ N,
  where `E` is as in Goal 4/5.

  Proof outline (matches the handwritten "Case 1 / Case 2" + dyadic-layer
  argument):
    Write `F(t) := |∑ a_r e(ξ_r t)|^2`.  Split `ℝ = I ∪ (ℝ∖I)`.

    Case `N ≪ T` (i.e. `N ≤ T`, the interesting case):
      Decompose `I` (and a neighbourhood of `I` in `ℝ∖I`) into ≈ `T/N`
      consecutive sub-intervals `J` of length `N`.  Group these `J`'s into
      *dyadic layers* `ℓ = 0, 1, …, ⌈log₂(T/N)⌉` according to
      `dist(J, ∂I) ~ 2^ℓ N`.
        • By Goal 5, `sup_{t∈J} |E(t)| ≪ (2^ℓ)^{-10}` for `J` in layer `ℓ`.
        • By Goal 3, `∫_J F(t) dt ≪ N` for each such `J` (a uniform bound,
          independent of `J`).
        • The number of `J`'s in layer `ℓ` is `≈ 2^ℓ` (for layers
          intersecting `I`) — or more precisely `O(2^ℓ)`.
      Summing:
        ∑_J ∫_J F |E| ≪ ∑_ℓ (#J in layer ℓ) · N · (2^ℓ)^{-10}
                      ≪ ∑_ℓ 2^ℓ · N · 2^{-10ℓ} = N ∑_ℓ 2^{-9ℓ} ≪ N,
      since `∑_ℓ 2^{-9ℓ}` is a convergent geometric series with sum `O(1)`.
      The far-away tail (`dist(t,∂I) ≫ T`) is handled by the *same* layer
      sum extended to `ℓ → ∞`, which still converges geometrically.

    Case `T ≪ N`:
      `I` is contained in (or comparable to) a single interval `J` of
      length `N`; apply Goal 3 directly to `J` to get `∫_J F dt ≪ N`, and
      `|E(t)| ≪ 1` uniformly (from Goal 5 with `dist(t,∂I) = O(N)`), so
      `∫_ℝ F |E| dt ≪ ∫_J F dt ≪ N`.
-/

theorem goal6_dyadic (B : BumpData) {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (N : ℝ) (hN : 0 < N)
    (hnorm : ∑ r, ‖a r‖ ^ 2 = 1)
    (hsep : SeparatedFreqs N ξ)
    (a0 b0 : ℝ) (hab : a0 ≤ b0) :
    ∃ C : ℝ, 0 < C ∧
      |∫ t : ℝ, ‖expSum a ξ t‖ ^ 2 *
          ((1 / N) * (∫ t₀ in Set.Icc a0 b0,
              ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2)
            - Set.indicator (Set.Icc a0 b0) (fun _ => (1:ℝ)) t)|
      ≤ C * N := by
  sorry
  -- Obtain the decay constant from Goal 5 and the uniform L² bound from
  -- Goal 3.  Perform the case split `N ≤ (b0 - a0)` vs `(b0-a0) < N`.
  -- In the first case, cover ℝ by dyadic-layer unions of length-N
  -- intervals as described above and sum the resulting geometric series
  -- (`tsum_geometric_of_lt_one` or `NNReal.tsum_geometric` for the bound
  -- `∑ 2^{-9ℓ} ≪ 1`).  In the second case, a single application of
  -- Goal 3 plus the uniform bound `|E| ≪ 1` (from Goal 5 with bounded
  -- `dist(t,∂I)/N`) suffices.

/-! ## Goal 7 : assembly — Lemma 3.1

  Combine Goals 4 and 6 (and Goal 1 for the normalization / trivial case)
  to obtain the full statement of Lemma 3.1:

      ∫_I |∑_{r=1}^R a_r e(ξ_r t)|^2 dt = (T + O(N)) ∑_{r=1}^R |a_r|^2.

  Concretely we phrase "`= (T+O(N)) · M`" as: there is a constant `C > 0`
  (independent of `I`, `a`, `ξ`, `N`, `T`, subject to the stated
  hypotheses) and a real number `θ` with `|θ| ≤ C` such that
      ∫_I |∑ a_r e(ξ_r t)|^2 dt = (T + θ N) · ∑ |a_r|^2.
-/

theorem lemma3_1 (B : BumpData) {R : ℕ} (a : Fin R → ℂ) (ξ : Fin R → ℝ)
    (N : ℝ) (hN : 0 < N) (hsep : SeparatedFreqs N ξ)
    (I : Set ℝ) (a0 b0 : ℝ) (T : ℝ) (hI : I = Set.Icc a0 b0)
    (hT : T = b0 - a0) (hab : a0 ≤ b0) :
    ∃ C : ℝ, 0 < C ∧ ∃ θ : ℝ, |θ| ≤ C ∧
      ∫ t in I, ‖expSum a ξ t‖ ^ 2
        = (T + θ * N) * ∑ r, ‖a r‖ ^ 2 := by
  set M : ℝ := ∑ r, ‖a r‖ ^ 2 with hM
  by_cases hM0 : M = 0
  · -- Trivial case: all `a r = 0`, both sides are `0`.
    refine ⟨1, one_pos, 0, by simp, ?_⟩
    have hzero : ∀ r, a r = 0 := by
      intro r
      have hsq : ‖a r‖ ^ 2 = 0 := by
        by_contra h
        have hpos : 0 < ‖a r‖ ^ 2 := lt_of_le_of_ne (sq_nonneg _) (Ne.symm h)
        have : 0 < M := by
          rw [hM]
          exact Finset.sum_pos' (fun i _ => sq_nonneg _) ⟨r, Finset.mem_univ r, hpos⟩
        exact hM0 (by linarith) |>.elim
      have := sq_eq_zero_iff.mp hsq
      exact norm_eq_zero.mp this
    rw [goal1_trivial_case a ξ hzero I, hM0]
    simp
  · -- Nontrivial case: normalize, apply Goals 4 and 6, unnormalize.
    set A : Fin R → ℂ := fun r => a r / (Real.sqrt M : ℂ) with hA
    have hAnorm : ∑ r, ‖A r‖ ^ 2 = 1 := goal1_normalization a M hM hM0
    -- expSum a ξ t = √M • expSum A ξ t, so |expSum a ξ t|^2 = M * |expSum A ξ t|^2.
    have hMpos : 0 < M := by
      have hMnn : 0 ≤ M := by rw [hM]; exact Finset.sum_nonneg (fun r _ => sq_nonneg _)
      exact lt_of_le_of_ne hMnn (Ne.symm hM0)
    have hexpand : ∀ t : ℝ,
        ‖expSum a ξ t‖ ^ 2 = M * ‖expSum A ξ t‖ ^ 2 := by
      intro t
      have hrescale : expSum a ξ t = (Real.sqrt M : ℂ) * expSum A ξ t := by
        unfold expSum A
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro r _
        rw [hA]
        field_simp
      rw [hrescale, norm_mul, Complex.norm_ofReal,
        abs_of_nonneg (Real.sqrt_nonneg M), mul_pow, Real.sq_sqrt hMpos.le]
    -- Apply Goal 4 to A.
    have h4 := goal4_identity B A ξ N hN hAnorm hsep I a0 b0 T hI hT
    -- Apply Goal 6 to A to bound the error term.
    obtain ⟨C, hCpos, hC⟩ := goal6_dyadic B A ξ N hN hAnorm hsep a0 b0 hab
    -- Combine: ∫_I |expSum a ξ t|^2 dt = M * ∫_I |expSum A ξ t|^2 dt
    --   = M * (T - (error term)) = M*T - M*(error), and |M*(error)| ≤ M*C*N.
    -- So θ := -M*(error)/(M*N) = -(error)/N, with |θ| ≤ C.
    have hMint : ∫ t in I, ‖expSum a ξ t‖ ^ 2
        = M * ∫ t in I, ‖expSum A ξ t‖ ^ 2 := by
      simp_rw [hexpand]
      rw [MeasureTheory.integral_const_mul]
    set err : ℝ := ∫ t : ℝ, ‖expSum A ξ t‖ ^ 2 *
        ((1 / N) * (∫ t₀ in I,
            ‖(psiHat B.ψ) ((t - t₀) / N)‖ ^ 2)
          - Set.indicator I (fun _ => (1:ℝ)) t) with herr
    have h4' : ∫ t in I, ‖expSum A ξ t‖ ^ 2 = T - err := by
      rw [herr]; rw [hI] at h4 ⊢; exact h4
    rw [hI] at hC
    refine ⟨C, hCpos, -err / N, ?_, ?_⟩
    · rw [abs_div, abs_neg, abs_of_pos hN]
      rw [hI] at herr
      have step : |err| / N ≤ (C * N) / N := (div_le_div_right hN).mpr hC
      rwa [mul_div_cancel_right₀ C (ne_of_gt hN)] at step
    · rw [hMint, h4']
      have hNne : N ≠ 0 := ne_of_gt hN
      field_simp
      ring

end
